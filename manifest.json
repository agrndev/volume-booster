{
  "manifest_version": 2,
  "name": "Volume Booster",
  "version": "1.0.0",
  "description": "Boost tab volume using the Web Audio API",
  "icons": {
    "128": "icons/icon128.png"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "@volume-booster"
    }
  },
  "browser_action": {
    "default_popup": "popup.html",
    "default_icon": {
      "128": "icons/icon128.png"
    },
    "default_title": "Volume Booster"
  },
  "permissions": [
    "activeTab",
    "storage",
    "tabs"
  ],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "scripts": ["background.js"],
    "persistent": false
  }
}
